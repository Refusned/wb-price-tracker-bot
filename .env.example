# ─── Telegram ──────────────────────────────────────────────────────────────
# Токен бота от @BotFather
BOT_TOKEN=1234567890:YOUR_BOT_TOKEN_HERE
# Список Telegram user IDs через запятую (whitelist владельцев).
# ВАЖНО: если пусто — доступ ЗАПРЕЩЁН ВСЕМ (deny-by-default). Укажи свой ID.
ALLOWED_USER_IDS=

# ─── Поисковый запрос на WB ────────────────────────────────────────────────
# Основной поисковый запрос
WB_QUERY=товар
# Дополнительные варианты через запятую — расширяет покрытие выдачи
WB_QUERY_VARIANTS=
# Минимальная цена для отображения в /top10 и алертах (отсекает "мусорные" листинги)
MIN_PRICE_RUB=9000

# ─── Фоновый поллинг и кэш ─────────────────────────────────────────────────
# Интервал обновления каталога (секунды)
WB_POLL_INTERVAL_SECONDS=600
# Максимальный возраст кэша (секунды)
MAX_CACHE_AGE_SECONDS=300

# ─── Алерты падения цены ───────────────────────────────────────────────────
ALERTS_ENABLED=true
# Порог падения цены для срабатывания алерта (% от средней)
ALERT_DROP_PERCENT=5
# Максимум алертов за один цикл (анти-спам)
ALERT_MAX_ITEMS_PER_CYCLE=3

# ─── HTTP-клиент WB ────────────────────────────────────────────────────────
WB_MAX_PAGES=1
WB_REQUEST_TIMEOUT_SECONDS=20
WB_HTTP_RETRIES=6
WB_HTTP_BACKOFF_SECONDS=1.0
WB_RATE_LIMIT_RPS=1.0

# ─── Хранилище ─────────────────────────────────────────────────────────────
SQLITE_PATH=data/app.db

# ─── Логирование ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Маржинальный калькулятор ──────────────────────────────────────────────
# СПП (Скидка постоянного покупателя) — % от цены
SPP_PERCENT=24.0
# Комиссия Wildberries — % от цены
WB_COMMISSION_PERCENT=15.0
# Логистика за единицу (₽)
LOGISTICS_COST_RUB=400.0
# Хранение за день за единицу (₽)
STORAGE_COST_PER_DAY_RUB=5.0
# Процент возвратов
RETURN_RATE_PERCENT=3.0
# Целевая цена продажи (0 = автоматически)
SELL_PRICE_RUB=0.0
# Целевая маржа (%)
TARGET_MARGIN_PERCENT=10.0
# Размер партии закупки
BATCH_SIZE=25

# ─── WB Seller API (опционально, для FBS-режима) ──────────────────────────
# JWT-токен из ЛК Wildberries → API → Создать новый токен
WB_SELLER_API_KEY=
# Интервал синхронизации с Seller API (секунды)
WB_SELLER_POLL_INTERVAL_SECONDS=1800
# Режим торговли: FBS / FBO
WB_TRADE_MODE=FBS
# Час и минута ежедневного брифинга (по МСК — Europe/Moscow)
BRIEFING_HOUR=9
BRIEFING_MINUTE=0

# ─── Расчёт прибыли (overridable через /settax, /setlogistics, /setacquiring) ──
PROFIT_TAX_PERCENT=2.0
PROFIT_LOGISTICS_PER_UNIT_RUB=182.0
PROFIT_ACQUIRING_PERCENT=0.0

# ─── Авто-ресинхронизация истории Seller API ──────────────────────────────
SELLER_FULL_RESYNC_DAYS=7

# ─── Ретеншен (чтобы БД не росла бесконечно) ───────────────────────────────
# Хранить price_history N дней (нужно ≥120 для counterfactual-анализа)
PRICE_HISTORY_RETENTION_DAYS=120
# Хранить arb_candidates N дней (пишется на каждом скане — без ретеншена БД пухнет)
ARB_CANDIDATE_RETENTION_DAYS=90
# Хранить наблюдения СПП (arb_buyer_spp_observations) N дней
ARB_OBSERVATION_RETENTION_DAYS=180

# ─── Безопасность ──────────────────────────────────────────────────────────
# HMAC-секрет для подписи Telegram callback-payload на мутирующих inline-кнопках.
# Сгенерировать: openssl rand -hex 32
# Бот ОТКАЗЫВАЕТСЯ стартовать с пустым секретом (защита от подделки callback'ов),
# КРОМЕ случая SHADOW_MODE=true (в shadow-режиме мутирующих кнопок нет).
CALLBACK_SIGNING_SECRET=
# Shadow mode: бот считает и показывает рекомендации, но НЕ выполняет автономных
# мутаций (не пишет наблюдения по кнопкам, не дёргает auto-observer).
# true — безопасный режим по умолчанию для первого деплоя.
SHADOW_MODE=true

# ─── Арбитражный сканер (опционально, требует WB_SELLER_API_KEY) ───────────
ARBITRAGE_ENABLED=false
ARBITRAGE_SCAN_INTERVAL_SECONDS=600
# Порог profit-per-ruble-per-day, %
ARBITRAGE_MIN_PPRD_PERCENT=0.25
ARBITRAGE_MIN_PROFIT_RUB=500
ARBITRAGE_MIN_MARGIN_PERCENT=8.0
ARBITRAGE_ALERT_COOLDOWN_HOURS=6
ARBITRAGE_DAILY_ALERT_CAP=30
ARBITRAGE_COHORT_MIN_SIZE=5
ARBITRAGE_DEFAULT_SPP_PERCENT=20.0
# WB-Кошелёк bonus (личный дисконт на чекауте), %
ARBITRAGE_WALLET_BONUS_PCT=6.0
# Путь к файлу с buyer-cookie (для авто-fetch личной цены)
WB_BUYER_COOKIE_PATH=data/wb_buyer_cookie.txt
# WB destination ID для card.wb.ru (Москва по умолчанию)
WB_BUYER_DEST_PARAM=-1257786

# ─── Прочее ────────────────────────────────────────────────────────────────
# Детектор поступления товара: мин. прирост остатка для prompt "что заплатил?"
STOCK_ARRIVAL_DELTA_THRESHOLD=5
# Фильтры /top10 по цвету (substring по item.name.lower()), через запятую
TOP10_EXCLUDE_KEYWORDS=
TOP10_INCLUDE_KEYWORDS=
# Подавлять per-order/per-sale уведомления (price-drop алерты не затрагиваются)
EVENT_ALERTS_ENABLED=true

# ─── LLM (Ollama Cloud) — основа для автоответов и будущего советника ───────
# Ключ Ollama Cloud (ollama.com/settings/keys). Пусто — все LLM-функции выключены.
OLLAMA_API_KEY=
# База API. Облако: https://ollama.com ; локальный Ollama: http://localhost:11434
LLM_BASE_URL=https://ollama.com
# Модель (сильнейшая облачная для русского + аналитики по умолчанию)
LLM_MODEL=deepseek-v4-pro
LLM_TIMEOUT_SECONDS=60

# ─── Автоответы на отзывы/вопросы WB ───────────────────────────────────────
# Требует OLLAMA_API_KEY и токен WB со scope «Вопросы и отзывы».
# ⚠️ true — бот САМ публикует ответы покупателям БЕЗ подтверждения. По умолч. OFF.
FEEDBACK_AUTO_REPLY_ENABLED=false
# Интервал опроса неотвеченных (секунды)
FEEDBACK_POLL_INTERVAL_SECONDS=900
# Сколько отзывов+вопросов отвечать за цикл (троттлит бэклог на первом запуске)
FEEDBACK_MAX_PER_CYCLE=10
# Токен WB со scope «Вопросы и отзывы». Пусто → берётся WB_SELLER_API_KEY.
WB_FEEDBACKS_API_KEY=
# Необязательная подпись в конце ответа (напр.: С уважением, команда магазина)
FEEDBACK_SIGNATURE=

# ─── Интерактивный LLM-агент по кабинету (кнопка «🤖 Ассистент» / /chat) ──────
# Многоходовой диалог: агент сам читает данные кабинета (ТОЛЬКО чтение) и при
# необходимости предлагает действие (закупка/настройки прибыли/ответ покупателю)
# с кнопкой подтверждения. Включён при OLLAMA_API_KEY + WB_SELLER_API_KEY.
AGENT_CHAT_ENABLED=true
# think в tool-loop. false работает (probe подтвердил) и дешевле по токенам.
AGENT_THINK=false
# Лимит обращений к инструментам за один ход (анти-зацикливание / стоимость)
AGENT_MAX_ITERATIONS=6
# Сколько последних ходов диалога держать в контексте
AGENT_HISTORY_LIMIT=16
