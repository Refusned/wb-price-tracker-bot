# ─── Telegram ──────────────────────────────────────────────────────────────
# Токен бота от @BotFather
BOT_TOKEN=1234567890:YOUR_BOT_TOKEN_HERE
# Список Telegram user IDs через запятую. Если пусто — доступ всем
ALLOWED_USER_IDS=

# ─── Поисковый запрос на WB ────────────────────────────────────────────────
# Основной поисковый запрос
WB_QUERY=товар
# Дополнительные варианты через запятую — расширяет покрытие выдачи
WB_QUERY_VARIANTS=
# Минимальная цена для отображения в /top10 и алертах (отсекает "мусорные" листинги)
MIN_PRICE_RUB=9000

# ─── Фоновый поллинг и кэш ─────────────────────────────────────────────────
# Интервал обновления каталога (секунды)
WB_POLL_INTERVAL_SECONDS=600
# Максимальный возраст кэша (секунды)
MAX_CACHE_AGE_SECONDS=300

# ─── Алерты падения цены ───────────────────────────────────────────────────
ALERTS_ENABLED=true
# Порог падения цены для срабатывания алерта (% от средней)
ALERT_DROP_PERCENT=5
# Максимум алертов за один цикл (анти-спам)
ALERT_MAX_ITEMS_PER_CYCLE=3

# ─── HTTP-клиент WB ────────────────────────────────────────────────────────
WB_MAX_PAGES=1
WB_REQUEST_TIMEOUT_SECONDS=20
WB_HTTP_RETRIES=6
WB_HTTP_BACKOFF_SECONDS=1.0
WB_RATE_LIMIT_RPS=1.0

# ─── Хранилище ─────────────────────────────────────────────────────────────
SQLITE_PATH=data/app.db

# ─── Логирование ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Маржинальный калькулятор ──────────────────────────────────────────────
# СПП (Скидка постоянного покупателя) — % от цены
SPP_PERCENT=24.0
# Комиссия Wildberries — % от цены
WB_COMMISSION_PERCENT=15.0
# Логистика за единицу (₽)
LOGISTICS_COST_RUB=400.0
# Хранение за день за единицу (₽)
STORAGE_COST_PER_DAY_RUB=5.0
# Процент возвратов
RETURN_RATE_PERCENT=3.0
# Целевая цена продажи (0 = автоматически)
SELL_PRICE_RUB=0.0
# Целевая маржа (%)
TARGET_MARGIN_PERCENT=10.0
# Размер партии закупки
BATCH_SIZE=25

# ─── WB Seller API (опционально, для FBS-режима) ──────────────────────────
# JWT-токен из ЛК Wildberries → API → Создать новый токен
WB_SELLER_API_KEY=
# Интервал синхронизации с Seller API (секунды)
WB_SELLER_POLL_INTERVAL_SECONDS=1800
# Режим торговли: FBS / FBO
WB_TRADE_MODE=FBS
# Час и минута ежедневного брифинга (по МСК)
BRIEFING_HOUR=9
BRIEFING_MINUTE=0

# ─── Расчёт прибыли (overridable через /settax, /setlogistics, /setacquiring) ──
PROFIT_TAX_PERCENT=2.0
PROFIT_LOGISTICS_PER_UNIT_RUB=182.0
PROFIT_ACQUIRING_PERCENT=0.0

# ─── Авто-ресинхронизация истории Seller API ──────────────────────────────
SELLER_FULL_RESYNC_DAYS=7
